rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }
    
    // 2. Global Safety Helpers
    function isValidId(id) {
      return id is string 
        && id.size() >= 1 
        && id.size() <= 128 
        && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    // 3. Validation Blueprints for Membro Entity
    function isValidMembro(data) {
      return data.keys().hasAll(['nome', 'pagamentos', 'updatedAt']) 
        && data.keys().size() == 3 
        && data.nome is string 
        && data.nome.size() >= 1 
        && data.nome.size() <= 200
        && data.pagamentos is list 
        && data.pagamentos.size() == 12
        && data.pagamentos[0] is bool
        && data.pagamentos[1] is bool
        && data.pagamentos[2] is bool
        && data.pagamentos[3] is bool
        && data.pagamentos[4] is bool
        && data.pagamentos[5] is bool
        && data.pagamentos[6] is bool
        && data.pagamentos[7] is bool
        && data.pagamentos[8] is bool
        && data.pagamentos[9] is bool
        && data.pagamentos[10] is bool
        && data.pagamentos[11] is bool;
    }
    
    // 4. Validation Blueprints for Configuracao Entity
    function isValidConfig(data) {
      return data.keys().hasAll(['valorMensalidade', 'senhaAdmin', 'chavePixGeral', 'senhaMembros', 'updatedAt'])
        && data.keys().size() == 5
        && data.valorMensalidade is number
        && data.valorMensalidade >= 0
        && data.senhaAdmin is string
        && data.senhaAdmin.size() >= 1
        && data.senhaAdmin.size() <= 100
        && data.chavePixGeral is string
        && data.chavePixGeral.size() <= 200
        && data.senhaMembros is string
        && data.senhaMembros.size() <= 100;
    }

    // 5. Match rules for membros collection
    match /membros/{membroId} {
      allow get, list: if true;
      
      allow create: if isValidId(membroId) 
        && isValidMembro(incoming())
        && incoming().updatedAt == request.time;
        
      allow update: if isValidId(membroId)
        && isValidMembro(incoming())
        && incoming().updatedAt == request.time;
        
      allow delete: if isValidId(membroId);
    }
    
    // 6. Match rules for config collection
    match /config/{configId} {
      allow get, list: if true;
      
      allow create: if isValidId(configId)
        && isValidConfig(incoming())
        && incoming().updatedAt == request.time;
        
      allow update: if isValidId(configId)
        && isValidConfig(incoming())
        && incoming().updatedAt == request.time;
        
      allow delete: if false;
    }
  }
}
